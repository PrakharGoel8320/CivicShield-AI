# CivicShield AI - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================
# BACKEND CONFIGURATION
# ============================================

# API URL - Where the backend server runs
API_URL=http://localhost:8000

# CORS Origins - Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Server Host and Port (if different from default)
# HOST=0.0.0.0
# PORT=8000

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# Backend API URL - MUST start with NEXT_PUBLIC_ to be accessible in browser
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================
# DATABASE (Optional - for future persistence)
# ============================================

# PostgreSQL connection string
# DATABASE_URL=postgresql://username:password@localhost:5432/civicshield

# Database pool settings
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================

# Maximum file upload size in bytes (default: 10MB)
# MAX_UPLOAD_SIZE=10485760

# Allowed file extensions
# ALLOWED_EXTENSIONS=.csv,.xlsx

# Upload directory
# UPLOAD_DIR=./uploads

# ============================================
# ML MODEL CONFIGURATION
# ============================================

# Model storage directory (if persisting models to disk)
# MODEL_STORAGE_DIR=./trained_models

# Default test size for train/test split
# DEFAULT_TEST_SIZE=0.2

# Random seed for reproducibility
# RANDOM_SEED=42

# ============================================
# REDIS (Optional - for caching and sessions)
# ============================================

# Redis connection URL
# REDIS_URL=redis://localhost:6379/0

# Session timeout in seconds
# SESSION_TIMEOUT=3600

# ============================================
# EMAIL NOTIFICATIONS (Optional)
# ============================================

# SMTP configuration for email alerts
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@civicshield.ai

# Admin email for alerts
# ADMIN_EMAIL=admin@yourdomain.com

# ============================================
# LOGGING
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# Log file location
# LOG_FILE=./logs/civicshield.log

# ============================================
# SECURITY
# ============================================

# Secret key for JWT tokens (generate with: openssl rand -hex 32)
# SECRET_KEY=your-secret-key-here-change-this-in-production

# JWT token expiration in minutes
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# API rate limiting
# RATE_LIMIT_PER_MINUTE=60

# ============================================
# PRODUCTION SETTINGS
# ============================================

# Environment: development, staging, production
# NODE_ENV=development

# Enable debug mode (set to false in production)
# DEBUG=true

# Enable API documentation (Swagger UI)
# ENABLE_DOCS=true

# ============================================
# MONITORING (Optional)
# ============================================

# Sentry DSN for error tracking
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Google Analytics ID
# GA_TRACKING_ID=UA-XXXXX-Y

# ============================================
# CLOUD STORAGE (Optional)
# ============================================

# AWS S3 for file storage
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=civicshield-data
# AWS_REGION=us-east-1

# ============================================
# NOTES
# ============================================

# 1. Never commit the actual .env file to version control
# 2. Keep production secrets secure and rotate regularly
# 3. Use different values for development, staging, and production
# 4. Generate strong random secrets for production use
# 5. Update CORS_ORIGINS to your actual domain in production
# 6. Set DEBUG=false in production for security

# For production deployment:
# - Replace localhost URLs with your actual domain
# - Enable HTTPS (use wss:// for WebSockets)
# - Set secure random SECRET_KEY
# - Configure proper CORS origins
# - Enable monitoring and logging
# - Setup automated backups

# Example production configuration:
# API_URL=https://api.yourdomain.com
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# DEBUG=false
# NODE_ENV=production
# SECRET_KEY=<generate-secure-random-key>
